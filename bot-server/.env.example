# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ID канала для уведомлений (можно задать через бота: /channel -1001234567890)
# Узнать ID: добавьте бота в канал как админа, затем перешлите любое сообщение боту @userinfobot
TELEGRAM_CHANNEL_ID=

# Путь к SQLite (по умолчанию data/bot.db)
# DATABASE_PATH=data/bot.db

# Опционально: секрет для заголовка X-Api-Key при запросах с Android
# API_SECRET=your-secret

# URL вашего сервера (для подсказки в боте при /new)
# API_BASE_URL=https://your-server.com
